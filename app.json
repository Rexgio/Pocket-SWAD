{
  "expo": {
    "name": "Pocket-SWAD",
    "slug": "Pocket-SWAD",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pocketswad",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/swad.webp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/swad.webp",
        "backgroundImage": "./assets/images/swad.webp",
        "monochromeImage": "./assets/images/swad.webp"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/swad.webp"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/swad.webp",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
