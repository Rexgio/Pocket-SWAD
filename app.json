{
  "expo": {
    "name": "Pocket-SWAD",
    "slug": "Pocket-SWAD",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pocketswad",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/swad.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/swad.png",
        "backgroundImage": "./assets/images/swad.png",
        "monochromeImage": "./assets/images/swad.png"
      },
      "package": "es.ugr.PocketSWAD"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/swad.webp"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/swad.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a030ab3-4bd0-474e-89b0-5cf38c6cd6c8"
      }
    }
  }
}
